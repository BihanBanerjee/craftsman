# Required: OpenRouter API key (all models accessed through OpenRouter)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-key-here

# Optional: Exa API key for semantic web search
# Falls back to DuckDuckGo if not set (no key required)
# Get your key at: https://exa.ai
EXA_API_KEY=your-exa-key-here